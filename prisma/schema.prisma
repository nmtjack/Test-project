generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccessLevel {
  FREE     @map("free")
  PRO      @map("pro")
  LIFETIME @map("lifetime")
  ADMIN    @map("admin")

  @@map("access_level")
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

enum ConversationType {
  DIRECT
  GROUP
}

enum CoopQuestStatus {
  DRAFT
  INVITED
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum CoopParticipantStatus {
  INVITED
  ACCEPTED
  DECLINED
}

model User {
  id              String    @id @default(cuid())
  email           String?   @unique
  emailVerified   DateTime? @map("email_verified")
  name            String?
  username        String?
  tag             String?
  image           String?   @map("profile_picture_url")
  avatarUrl       String?   @map("avatar_url")
  accessLevel     AccessLevel @default(FREE) @map("access_level")
  googleProviderId String?  @unique @map("google_provider_id")
  passwordHash    String?   @map("password_hash")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  lastLoginAt     DateTime? @map("last_login_at")
  accounts        Account[]
  sessions        Session[]
  sentFriendships Friendship[] @relation("FriendRequester")
  receivedFriendships Friendship[] @relation("FriendAddressee")
  conversationMembers ConversationMember[]
  messages        Message[]
  createdCoopQuests CoopQuest[] @relation("CoopCreator")
  coopParticipants CoopQuestParticipant[]
  plannerState    PlannerState?

  @@unique([username, tag])
  @@index([username])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Friendship {
  id          String           @id @default(cuid())
  requesterId String          @map("requester_id")
  addresseeId String          @map("addressee_id")
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  requester   User             @relation("FriendRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee   User             @relation("FriendAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([addresseeId, status])
  @@map("friendships")
}

model Conversation {
  id        String             @id @default(cuid())
  type      ConversationType
  name      String?
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")
  members   ConversationMember[]
  messages  Message[]

  @@map("conversations")
}

model ConversationMember {
  id             String       @id @default(cuid())
  conversationId String       @map("conversation_id")
  userId         String       @map("user_id")
  joinedAt       DateTime     @default(now()) @map("joined_at")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("conversation_members")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String       @map("conversation_id")
  senderId       String       @map("sender_id")
  body           String       @db.Text
  createdAt      DateTime     @default(now()) @map("created_at")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}

model CoopQuest {
  id             String       @id @default(cuid())
  creatorId      String       @map("creator_id")
  title          String
  description    String       @default("")
  activityDate   DateTime     @map("activity_date")
  address        String
  googleMapsUrl  String       @map("google_maps_url")
  status         CoopQuestStatus @default(INVITED)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  creator        User         @relation("CoopCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  participants   CoopQuestParticipant[]

  @@index([creatorId, activityDate])
  @@map("coop_quests")
}

model CoopQuestParticipant {
  id          String                @id @default(cuid())
  coopQuestId String               @map("coop_quest_id")
  userId      String               @map("user_id")
  status      CoopParticipantStatus @default(INVITED)
  createdAt   DateTime              @default(now()) @map("created_at")
  coopQuest   CoopQuest             @relation(fields: [coopQuestId], references: [id], onDelete: Cascade)
  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([coopQuestId, userId])
  @@map("coop_quest_participants")
}

model PlannerState {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  data      Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("planner_states")
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  DIRTY
  MAINTENANCE
  BLOCKED
}

enum BookingStatus {
  UPCOMING
  ACTIVE
  CHECKED_OUT
  CANCELLED
  NO_SHOW
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
}

enum OrderStatus {
  OPEN
  SENT_TO_KITCHEN
  SERVED
  CLOSED
}

enum BillStatus {
  DRAFT
  PAID
  VOID
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
}

enum BillLineSource {
  ROOM
  POS
  MANUAL
}

enum RoomType {
  STANDARD
  DELUXE
  SUITE
  VILLA
  DORMITORY
}

enum BedType {
  SINGLE
  TWIN
  DOUBLE
  KING
  QUEEN
}

enum IdType {
  PASSPORT
  NATIONAL_ID
  DRIVER_LICENSE
}

enum BookingSource {
  WALK_IN
  PHONE
  BOOKING_DOT_COM
  AGODA
  AIRBNB
  DIRECT_WEBSITE
}

enum DepositStatus {
  UNPAID
  PARTIAL
  PAID
}

model Room {
  id             String            @id @default(cuid())
  number         String            @unique
  name           String            @default("")
  type           String
  roomType       RoomType          @default(STANDARD)
  floor          Int
  maxAdults      Int               @default(2)
  maxChildren    Int               @default(0)
  basePrice      Decimal           @db.Decimal(10, 2)
  weekendPrice   Decimal?          @db.Decimal(10, 2)
  bedType        BedType           @default(QUEEN)
  sizeSqm        Int?
  description    String            @default("")
  status         RoomStatus        @default(AVAILABLE)
  isActive       Boolean           @default(true)
  wifiPassword   String            @default("")
  housekeepingNote String          @default("")
  amenities      RoomAmenity[]
  images         RoomImage[]
  blockedDates   BlockedDate[]
  housekeepingLogs HousekeepingLog[]
  bookings       Booking[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model Guest {
  id              String    @id @default(cuid())
  name            String
  phone           String
  email           String?
  nationality     String?
  idType          IdType?
  idNumber        String?
  dateOfBirth     DateTime?
  notes           String    @default("")
  specialRequests String    @default("")
  bookings        Booking[]
  bills           Bill[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([phone])
  @@index([email])
}

model Booking {
  id                 String        @id @default(cuid())
  bookingId          String        @unique
  guestId            String
  roomId             String
  checkIn            DateTime
  checkOut           DateTime
  adults             Int           @default(1)
  children           Int           @default(0)
  source             BookingSource @default(WALK_IN)
  otaReference       String?
  status             BookingStatus @default(UPCOMING)
  roomRateSnapshot   Decimal       @default(0) @db.Decimal(10, 2)
  totalNights        Int           @default(1)
  estimatedTotal     Decimal       @default(0) @db.Decimal(10, 2)
  depositAmount      Decimal       @default(0) @db.Decimal(10, 2)
  depositMethod      PaymentMethod?
  depositStatus      DepositStatus @default(UNPAID)
  internalNotes      String        @default("")
  guest              Guest         @relation(fields: [guestId], references: [id], onDelete: Cascade)
  room               Room          @relation(fields: [roomId], references: [id])
  orders             Order[]
  bills              Bill[]
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([checkIn, checkOut])
  @@index([status])
}

model RoomAmenity {
  id        String   @id @default(cuid())
  roomId    String
  name      String
  isCustom  Boolean  @default(false)
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([roomId, name])
}

model RoomImage {
  id        String   @id @default(cuid())
  roomId    String
  path      String
  alt       String   @default("")
  isCover   Boolean  @default(false)
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model BlockedDate {
  id        String   @id @default(cuid())
  roomId    String
  startDate DateTime
  endDate   DateTime
  reason    String
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([roomId, startDate, endDate])
}

model HousekeepingLog {
  id          String     @id @default(cuid())
  roomId      String
  fromStatus  RoomStatus?
  toStatus    RoomStatus
  note        String     @default("")
  changedBy   String     @default("Front desk")
  room        Room       @relation(fields: [roomId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())

  @@index([roomId, createdAt])
}

model RestaurantTable {
  id        String      @id @default(cuid())
  number    String      @unique
  seats     Int
  status    TableStatus @default(AVAILABLE)
  orders    Order[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model MenuCategory {
  id        String     @id @default(cuid())
  name      String     @unique
  items     MenuItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model MenuItem {
  id         String       @id @default(cuid())
  categoryId String
  name       String
  price      Decimal      @db.Decimal(10, 2)
  category   MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([categoryId])
}

model Order {
  id        String           @id @default(cuid())
  orderId   String           @unique
  tableId   String
  bookingId String?
  status    OrderStatus      @default(OPEN)
  total     Decimal          @default(0) @db.Decimal(10, 2)
  table     RestaurantTable  @relation(fields: [tableId], references: [id])
  booking   Booking?         @relation(fields: [bookingId], references: [id])
  items     OrderItem[]
  billLinks BillOrder[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([status])
  @@index([tableId])
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  menuItemId String
  quantity   Int
  unitPrice  Decimal  @db.Decimal(10, 2)
  locked     Boolean  @default(false)
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([orderId, menuItemId])
}

model Bill {
  id            String         @id @default(cuid())
  billId        String         @unique
  guestId       String?
  bookingId     String?
  status        BillStatus     @default(DRAFT)
  taxRate       Decimal        @default(0) @db.Decimal(5, 2)
  subtotal      Decimal        @default(0) @db.Decimal(10, 2)
  taxTotal      Decimal        @default(0) @db.Decimal(10, 2)
  grandTotal    Decimal        @default(0) @db.Decimal(10, 2)
  guest         Guest?         @relation(fields: [guestId], references: [id])
  booking       Booking?       @relation(fields: [bookingId], references: [id])
  lineItems     BillLineItem[]
  orderLinks    BillOrder[]
  payment       Payment?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([status])
  @@index([createdAt])
}

model BillLineItem {
  id          String         @id @default(cuid())
  billId      String
  description String
  quantity    Int
  unitPrice   Decimal        @db.Decimal(10, 2)
  total       Decimal        @db.Decimal(10, 2)
  source      BillLineSource
  bill        Bill           @relation(fields: [billId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now())
}

model BillOrder {
  billId  String
  orderId String
  bill    Bill   @relation(fields: [billId], references: [id], onDelete: Cascade)
  order   Order  @relation(fields: [orderId], references: [id])

  @@id([billId, orderId])
}

model Payment {
  id        String        @id @default(cuid())
  billId    String        @unique
  amount    Decimal       @db.Decimal(10, 2)
  method    PaymentMethod
  paidAt    DateTime      @default(now())
  bill      Bill          @relation(fields: [billId], references: [id], onDelete: Cascade)
}
